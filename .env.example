# If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

AUTH_SECRET="my-auth-secret" # required (generate your own if you deploy anywhere)

# Payload
PAYLOAD_SECRET="my-payload-secret" # required (generate your own if you deploy anywhere)

NEXT_PUBLIC_BASE_URL="http://localhost:3000/"
AUTH_ADDITIONAL_TRUSTED_ORIGINS="" # optional comma-separated extra callback origins (for example a fixed vercel.app host)
AUTH_BASE_URL="" # optional single auth host override; leave unset if OAuth should follow the current request host
BETTER_AUTH_BASE_URL="" # optional single auth host override; leave unset for multi-origin OAuth
BETTER_AUTH_URL="" # optional single auth host override; leave unset for multi-origin OAuth
NEXT_PUBLIC_BETTER_AUTH_URL="" # optional client-side auth base override; leave unset for multi-origin OAuth
GENERATE_CONSTANTS="false" # leave this false otherwise you will have missing data

# Logs
DISCORD_ROLLUP_WEBHOOK_URL="" # optional
DISCORD_CHANGE_REQUEST_WEBHOOK_URL="" # optional

# Discord Auth
AUTH_DISCORD_ID="" # only required for discord auth
AUTH_DISCORD_SECRET="" # only required for discord auth
# Discord Bot
DISCORD_BOT_CLIENT_ID=""
DISCORD_BOT_TOKEN=""
DISCORD_BOT_PUBLIC_KEY=""
DISCORD_BOT_GUILD_IDS="" # comma separated list (use your server if you're testing bot development)

# Drizzle
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sharply-dev

# Email
RESEND_EMAIL_FROM="" # optional (required if you want email auth)
RESEND_EMAIL_CONTACT="" # optional (defaults to RESEND_EMAIL_FROM if unset)
RESEND_API_KEY="" # optional (required if you want email auth)

# Development auth bypass
DEV_AUTH="" # optional (set to true to enable /api/dev-login outside production only)
DEV_AUTH_EMAIL="dev@sharply.local" # optional (used when DEV_AUTH=true and no existing user matches)
DEV_AUTH_LOCALHOST_ONLY="true" # optional (default-safe localhost host check for /api/dev-login; set false to allow other dev hosts)

# Vercel
CRON_SECRET="" # optional (generate your own)

# OpenAI
OPENAI_API_KEY="" # optional

# UploadThing
UPLOADTHING_TOKEN="" # optional

# Google
AUTH_GOOGLE_ID="" # optional
AUTH_GOOGLE_SECRET="" # optional
